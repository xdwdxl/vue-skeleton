{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --project tsconfig.federation.json",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --project tsconfig.federation.json",
    "watch": "vite build --watch",
    "preview": "vite preview --port 5000",
    "format": "prettier --write \"src/**/*.{vue,ts,js,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,json,css,scss}\"",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json || npx tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "test:coverage": "vitest run --coverage && node fix-lcov.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@builder.io/sdk-vue": "^5.2.0",
    "@fontsource/open-sans": "^5.2.7",
    "apexcharts": "^5.10.4",
    "axios": "^1.13.6",
    "crypto-js": "^4.2.0",
    "dhtmlx-gantt": "^9.1.3",
    "element-plus": "^2.13.5",
    "flag-icons": "^7.5.0",
    "grid-layout-plus": "^1.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "5.0.3",
    "vue3-apexcharts": "^1.11.1"
  },
  "optionalDependencies": {
    "@module-federation/vite": "^1.13.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-onboarding": "^10.3.0",
    "@storybook/addon-vitest": "^10.3.0",
    "@storybook/vue3-vite": "^10.3.0",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.0",
    "eslint-plugin-vue": "^10.8.0",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "storybook": "^10.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-svg-icons-ng": "^1.5.2",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "3.2.5"
  }
}
